{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=observabilitylab;Username=lab;Password=lab_secret"
  },

  
    "EvolutionApi": {
      "BaseUrl": "http://localhost:8088",
      "ApiKey": "observabilitylab-key",

      "TimeoutSeconds": 30,
      "RetryCount": 3,

      "DefaultInstance": "lab-instance",
      "ApiVersion": "v1",

      "EnableDebugLogging": true,
      "LogPayloads": false,

      "CircuitBreaker": {
        "FailureThreshold": 5,
        "DurationSeconds": 30,
        "FailureRatio": 0.5
      }
    }
  }
